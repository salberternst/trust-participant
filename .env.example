COMPOSE_PROJECT_NAME=trust-participant
COMPOSE_PROJECT_PREFIX=trust
TRUST_PARTICIPANT_EDGE_NETWORK=trust-edge
TRUST_PARTICIPANT_EDGE_NETWORK_EXTERNAL=false

PARTICIPANT_ROLE=participant
PARTICIPANT_BPN=BPNL00000003AYRE
PARTICIPANT_BPN_BASE64=QlBOTDAwMDAwMDAzQVlSRQ==
PARTICIPANT_CONTEXT_ID=596b0330-76ec-5c8e-af01-24ba6a21d4e6

# For did:web this host must resolve publicly when federating outside Docker.
# The resulting participant DID is did:web:${PARTICIPANT_DID_HOST}:${PARTICIPANT_BPN}
PARTICIPANT_DID_HOST=participant.example.org
PUBLIC_SCHEME=https
USE_HTTPS_DID_WEB=true

# Public addresses announced to counterparties.
PUBLIC_DSP_CALLBACK_ADDRESS=https://participant.example.org/api/v1/dsp
PUBLIC_DATAPLANE_BASE_URL=https://participant.example.org/api/public

# Trust services provided by the trust operator.
ISSUER_DID_HOST=issuer.example.org
BPN_ISSUER=BPNL00000003CRHK
BDRS_SERVER_URL=https://bdrs.example.org/api/directory

IDENTITYHUB_TAG=0.3.2
TRACTUSX_EDC_TAG=0.12.1
POSTGRES_USER=user
POSTGRES_PASSWORD=password
VAULT_DEV_ROOT_TOKEN_ID=root
EDC_API_KEY=password
IDENTITYHUB_API_KEY=

JAVA_TOOL_OPTIONS=-Xmx256m
OTEL_SDK_DISABLED=true
OTEL_JAVAAGENT_ENABLED=false

# Local bind ports. Keep these on loopback unless you intentionally expose admin APIs.
CONTROLPLANE_MANAGEMENT_HOST_PORT=29281
IDENTITYHUB_IDENTITY_HOST_PORT=29282
PUBLIC_HTTP_HOST_PORT=8080
