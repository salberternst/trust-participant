COMPOSE_PROJECT_NAME=trust-participant
COMPOSE_PROJECT_PREFIX=trust

# Network categories:
# - backend: Docker-internal only (Postgres, Vault, init jobs)
# - internal: participant application network for company/private services
# - public: only public gateways and reverse proxies
TRUST_PARTICIPANT_PUBLIC_NETWORK=trust-public
TRUST_PARTICIPANT_PUBLIC_NETWORK_EXTERNAL=false

PARTICIPANT_ROLE=participant
PARTICIPANT_BPN=BPNL00000003AYRE
PARTICIPANT_BPN_BASE64=QlBOTDAwMDAwMDAzQVlSRQ==
PARTICIPANT_CONTEXT_ID=596b0330-76ec-5c8e-af01-24ba6a21d4e6

# Public dataspace URL. This is the only required externally reachable participant URL.
PARTICIPANT_PUBLIC_HOST=participant.external.test
PARTICIPANT_DID_HOST=participant.external.test
PUBLIC_DSP_CALLBACK_ADDRESS=https://participant.external.test/api/v1/dsp
PUBLIC_DATAPLANE_BASE_URL=https://participant.external.test/api/public
USE_HTTPS_DID_WEB=true

# Internal/company URL served by the internal gateway.
PARTICIPANT_INTERNAL_HOST=participant.internal.test

# Trust services provided by the trust operator.
ISSUER_DID_HOST=issuer.external.test
BPN_ISSUER=BPNL00000003CRHK
BDRS_SERVER_URL=https://issuer.external.test/api/directory

IDENTITYHUB_TAG=0.3.2
TRACTUSX_EDC_TAG=0.12.1
POSTGRES_USER=user
POSTGRES_PASSWORD=password
VAULT_DEV_ROOT_TOKEN_ID=root
EDC_API_KEY=password
IDENTITYHUB_API_KEY=

JAVA_TOOL_OPTIONS=-Xmx256m
OTEL_SDK_DISABLED=true
OTEL_JAVAAGENT_ENABLED=false

# Local bind ports. Use a real reverse proxy for production TLS/public DNS.
PUBLIC_HTTP_BIND=127.0.0.1
PUBLIC_HTTP_HOST_PORT=8080
INTERNAL_HTTP_BIND=127.0.0.1
INTERNAL_HTTP_HOST_PORT=8081
